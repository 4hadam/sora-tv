# Example environment variables for Sora TV
# Copy to .env and fill values as needed

# NODE
NODE_ENV=development
PORT=5001

# Database (optional) - Postgres connection string
DATABASE_URL=
# or
PG_CONN_STRING=

# Optional API key to protect proxy endpoints
API_KEY=

# Host whitelist for proxy (comma-separated). Empty = allow all
ALLOWED_HOSTS=

# CORS origin header value for API
CORS_ORIGIN=*

# Rate limiting (milliseconds and max requests)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Scripts behavior
AUTO_PUSH=false
